<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEWRELLA | Exclusive</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            background:
                radial-gradient(circle at 15% 20%, rgba(30, 58, 138, 0.18), transparent 28%),
                radial-gradient(circle at 85% 25%, rgba(15, 23, 42, 0.25), transparent 24%),
                radial-gradient(circle at 50% 85%, rgba(0, 0, 0, 0.2), transparent 28%),
                linear-gradient(180deg, #020617 0%, #000000 100%);
        }

        .glass-liquid {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
            backdrop-filter: blur(32px) saturate(200%);
            -webkit-backdrop-filter: blur(32px) saturate(200%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow:
                inset 0 1px 1px rgba(255, 255, 255, 0.1),
                0 30px 60px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(255, 255, 255, 0.01);
        }

        .glass-soft {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 15px 45px rgba(0, 0, 0, 0.45);
        }

        .glass-stroke {
            position: relative;
        }

        .glass-stroke::before {
            content: "";
            position: absolute;
            inset: 1px;
            border-radius: inherit;
            pointer-events: none;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent 28%), radial-gradient(circle at top left, rgba(255, 255, 255, 0.12), transparent 35%);
            opacity: 0.7;
        }



        .text-glow {
            text-shadow: 0 0 30px rgba(255, 255, 255, 0.10);
        }

        .btn-liquid {
            position: relative;
            overflow: hidden;
        }

        .btn-liquid::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 25%, rgba(255, 255, 255, 0.35) 50%, transparent 75%);
            transform: translateX(-120%);
            transition: transform 0.9s ease;
        }

        .btn-liquid:hover::before {
            transform: translateX(120%);
        }

        .scroll-reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .scroll-reveal.in-view {
            opacity: 1;
            transform: translateY(0);
        }

        .delay-100 {
            transition-delay: 100ms;
        }

        .delay-200 {
            transition-delay: 200ms;
        }

        .delay-300 {
            transition-delay: 300ms;
        }

        .delay-400 {
            transition-delay: 400ms;
        }

        @keyframes floatY {

            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-14px);
            }
        }

        @keyframes floatYReverse {

            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(14px);
            }
        }

        @keyframes liquidRotate {
            0% {
                transform: rotate(0deg);
                border-radius: 42% 58% 65% 35% / 38% 44% 56% 62%;
            }

            50% {
                border-radius: 58% 42% 34% 66% / 62% 50% 50% 38%;
            }

            100% {
                transform: rotate(360deg);
                border-radius: 42% 58% 65% 35% / 38% 44% 56% 62%;
            }
        }

        .animate-float-soft {
            animation: floatY 8s ease-in-out infinite;
        }

        .animate-float-reverse {
            animation: floatYReverse 10s ease-in-out infinite;
        }

        .animate-liquid-blob {
            animation: liquidRotate 24s linear infinite;
        }

        .mask-horizontal {
            -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
            mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        }

        @keyframes marqueeX {
            100% {
                transform: translateX(calc(-50% - 1rem));
            }
        }

        .animate-marquee {
            display: flex;
            width: max-content;
            animation: marqueeX 32s linear infinite;
        }

        .animate-marquee:hover {
            animation-play-state: paused;
        }

        .product-card {
            position: relative;
            overflow: hidden;
        }

        .product-card::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            pointer-events: none;
            background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(255, 255, 255, 0.18), transparent 28%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .product-card:hover::after {
            opacity: 1;
        }

        .faq-item.open .faq-icon {
            transform: rotate(45deg);
        }

        .faq-item.open .faq-answer {
            max-height: 300px;
            opacity: 1;
        }

        .faq-answer {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition: all 0.45s ease;
        }
    </style>
</head>

<body
    class="font-[Inter] bg-[#050505] text-zinc-300 overflow-x-hidden min-h-screen relative selection:bg-zinc-800 selection:text-white">

    <!-- Background -->
    <div class="fixed inset-0 pointer-events-none z-[-1]">

        <div class="absolute -top-24 left-[5%] h-[28rem] w-[28rem] rounded-full bg-blue-900/20 blur-[120px]"></div>
        <div class="absolute top-[18%] right-[8%] h-[24rem] w-[24rem] rounded-full bg-slate-900/30 blur-[120px]"></div>
        <div class="absolute bottom-[8%] left-[30%] h-[22rem] w-[22rem] rounded-full bg-blue-950/10 blur-[120px]"></div>
        <div class="absolute top-[12%] left-[12%] h-72 w-72 bg-blue-900/5 blur-[90px] animate-liquid-blob"></div>
        <div class="absolute bottom-[8%] right-[10%] h-80 w-80 bg-blue-800/5 blur-[100px] animate-liquid-blob"></div>
    </div>

    <!-- Global Floating Glass Navbar -->
    <!-- Global Floating Glass Navbar -->
    <nav
        class="fixed top-4 md:top-6 left-1/2 -translate-x-1/2 w-[92%] lg:w-[70%] max-w-5xl z-[60] bg-white/[0.04] backdrop-blur-[24px] border border-white/10 rounded-full flex items-center justify-between px-6 md:px-8 py-3 md:py-4 transition-all duration-300 hover:bg-white/[0.06] shadow-[0_20px_40px_rgba(0,0,0,0.5)]">

        <!-- Left: Branding -->
        <a href="/" class="flex flex-col">
            <span class="text-lg md:text-xl font-black tracking-[0.2em] text-white">NEWRELLA</span>
        </a>

        <!-- Center: Desktop Links -->
        <div class="hidden md:flex items-center gap-10">
            <a href="/"
                class="text-xs uppercase tracking-[0.25em] font-medium text-zinc-400 hover:text-white transition-colors relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[1px] after:bg-white hover:after:w-full after:transition-all after:duration-300">Home</a>
            <a href="/shop"
                class="text-xs uppercase tracking-[0.25em] font-medium text-zinc-400 hover:text-white transition-colors relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[1px] after:bg-white hover:after:w-full after:transition-all after:duration-300">Shop</a>
            <a href="/order-tracking"
                class="text-xs uppercase tracking-[0.25em] font-medium text-zinc-400 hover:text-white transition-colors relative after:content-[''] after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[1px] after:bg-white hover:after:w-full after:transition-all after:duration-300">Order
                Tracking</a>
        </div>

        <!-- Right: Actions -->
        <div class="flex items-center gap-6">
            <a href="/cart" class="text-zinc-400 hover:text-white transition-colors flex items-center gap-2 group">
                <i class="ri-shopping-bag-line text-lg group-hover:scale-110 transition-transform"></i>
            </a>

            <!-- Authentication State -->
            <% if (typeof loggedIn !=='undefined' && loggedIn) { %>
                <a href="/users/logout"
                    class="text-xs uppercase tracking-[0.1em] font-bold text-red-400 hover:text-red-300 transition-colors">Logout</a>
                <a href="/profile"
                    class="w-8 h-8 rounded-full border border-white/20 bg-white/5 flex items-center justify-center hover:bg-white hover:text-black transition-colors">
                    <i class="ri-user-3-fill"></i>
                </a>
                <% } else { %>
                    <button onclick="window.toggleAuthModal && window.toggleAuthModal()"
                        class="text-xs uppercase tracking-[0.1em] font-bold text-white hover:text-zinc-300 transition-colors hidden md:block">Login</button>
                    <button onclick="window.toggleAuthModal && window.toggleAuthModal()"
                        class="w-8 h-8 rounded-full border border-white/20 bg-white text-black flex items-center justify-center hover:bg-zinc-200 transition-colors">
                        <i class="ri-key-2-line"></i>
                    </button>
                    <% } %>

                        <!-- Mobile Menu Toggle -->
                        <button onclick="toggleMobileMenu()"
                            class="md:hidden text-white w-8 h-8 rounded-full flex items-center justify-center bg-white/10 hover:bg-white/20 border border-white/10 relative z-[70]">
                            <i id="menu-icon" class="ri-menu-line transition-transform duration-300"></i>
                        </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-[65] pointer-events-none opacity-0 transition-all duration-500">
        <!-- Backdrop blur -->
        <div class="absolute inset-0 bg-black/60 backdrop-blur-xl"></div>

        <!-- Menu Content -->
        <div class="relative h-full flex flex-col items-center justify-center gap-8 px-6">
            <a href="/" onclick="toggleMobileMenu()"
                class="text-2xl font-bold uppercase tracking-[0.3em] text-white hover:text-blue-400 transition-colors">Home</a>
            <a href="/shop" onclick="toggleMobileMenu()"
                class="text-2xl font-bold uppercase tracking-[0.3em] text-white hover:text-blue-400 transition-colors">Shop</a>
            <a href="/order-tracking" onclick="toggleMobileMenu()"
                class="text-2xl font-bold uppercase tracking-[0.3em] text-white hover:text-blue-400 transition-colors">Order
                Tracking</a>

            <div class="mt-8 pt-8 border-t border-white/10 w-full max-w-[200px] flex flex-col gap-6 items-center">
                <a href="/cart" onclick="toggleMobileMenu()" class="flex items-center gap-3 text-zinc-400">
                    <i class="ri-shopping-bag-line text-xl"></i>
                    <span class="text-xs uppercase tracking-widest font-bold">Shopping Bag</span>
                </a>
                <% if (typeof loggedIn !=='undefined' && loggedIn) { %>
                    <a href="/profile" onclick="toggleMobileMenu()"
                        class="text-xs uppercase tracking-widest font-bold text-white">Profile Control</a>
                    <a href="/users/logout" class="text-xs uppercase tracking-widest font-bold text-red-500">Terminate
                        Protocol</a>
                    <% } else { %>
                        <button onclick="toggleMobileMenu(); window.toggleAuthModal && window.toggleAuthModal()"
                            class="text-xs uppercase tracking-widest font-bold text-white bg-white/10 w-full py-4 rounded-full border border-white/20">Login
                            / Join</button>
                        <a href="/owners/products" onclick="toggleMobileMenu()"
                            class="text-[9px] uppercase tracking-[0.2em] text-zinc-500 font-bold hover:text-white transition-colors">Owner
                            Terminal</a>
                        <% } %>
            </div>

            <button onclick="toggleMobileMenu()"
                class="absolute top-8 right-8 text-zinc-500 hover:text-white transition-colors">
                <i class="ri-close-line text-3xl"></i>
            </button>
        </div>
    </div>

    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('menu-icon');
            const body = document.body;

            if (menu.classList.contains('opacity-0')) {
                // Open
                menu.classList.remove('opacity-0', 'pointer-events-none');
                icon.classList.replace('ri-menu-line', 'ri-close-line');
                icon.style.transform = 'rotate(90deg)';
                body.style.overflow = 'hidden';
            } else {
                // Close
                menu.classList.add('opacity-0', 'pointer-events-none');
                icon.classList.replace('ri-close-line', 'ri-menu-line');
                icon.style.transform = 'rotate(0deg)';
                body.style.overflow = '';
            }
        }
    </script>
<%- include('./partials/header') %>

    <% if (typeof success !=='undefined' && success && success.length> 0) { %>
        <div
            class="fixed top-24 left-1/2 -translate-x-1/2 z-[70] px-6 py-3 rounded-full glass-soft border border-emerald-500/30 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
            <span
                class="inline-flex items-center gap-2 text-emerald-300 text-[10px] uppercase tracking-[0.2em] font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                <%= success %>
            </span>
        </div>
        <% } %>

            <% if (typeof error !=='undefined' && error && error.length> 0) { %>
                <div
                    class="fixed top-24 left-1/2 -translate-x-1/2 z-[70] px-6 py-3 rounded-full glass-soft border border-red-500/30 shadow-[0_0_20px_rgba(239,68,68,0.15)]">
                    <span
                        class="inline-flex items-center gap-2 text-red-300 text-[10px] uppercase tracking-[0.2em] font-bold">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                        <%= error %>
                    </span>
                </div>
                <% } %>

                    <% const cartItems=(products || []).filter((item)=> item && typeof item === 'object');
                        const subtotal = cartItems.reduce((acc, product) => acc + (Number(product.price) || 0), 0);
                        const discountTotal = cartItems.reduce((acc, product) => acc + (Number(product.discount) || 0),
                        0);
                        const platformFee = cartItems.length > 0 ? 20 : 0;
                        const finalBill = (Number(bill) || 0) + platformFee;
                        %>

                        <main
                            class="mx-auto w-full max-w-7xl pt-24 md:pt-36 pb-20 px-5 md:px-10 min-h-[calc(100vh-80px)] text-white relative z-10">
                            <div
                                class="mb-8 md:mb-10 flex items-end justify-between border-b border-white/10 pb-4 md:pb-6 scroll-reveal">
                                <div>
                                    <span
                                        class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-1 md:mb-2 block">Checkout</span>
                                    <h1 class="text-2xl md:text-5xl font-semibold tracking-[-0.04em] text-white">
                                        Shopping Bag</h1>
                                </div>
                                <p class="text-[10px] md:text-xs uppercase tracking-[0.25em] font-medium text-zinc-500">
                                    <%= cartItems.length %> Piece(s)
                                </p>
                            </div>

                            <% if (cartItems.length===0) { %>
                                <div
                                    class="glass-soft rounded-[2rem] md:rounded-[2.5rem] p-10 md:p-16 text-center mt-10 scroll-reveal">
                                    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-white">Your bag is
                                        empty</h2>
                                    <p class="mt-3 md:mt-4 text-zinc-400 max-w-md mx-auto text-sm">Acquire pieces from
                                        the archive to build your collection.</p>
                                    <a href="/shop"
                                        class="mt-6 md:mt-8 btn-liquid inline-flex items-center justify-center rounded-full bg-white text-black px-6 md:px-8 py-3.5 md:py-4 text-[10px] font-bold uppercase tracking-[0.2em] hover:-translate-y-0.5 transition">Explore
                                        Archive</a>
                                </div>
                                <% } else { %>
                                    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
                                        <section class="space-y-4 md:space-y-6 lg:col-span-8 scroll-reveal">
                                            <% cartItems.forEach(function(product) { %>
                                                <article
                                                    class="glass-liquid glass-stroke rounded-[1.5rem] md:rounded-[2rem] p-1.5 md:p-2 transition-all group overflow-hidden"
                                                    class='bg-[<%= product.bgcolor || ' #040405' %>40]'>
                                                    <div class="flex flex-row h-full rounded-[1.25rem] md:rounded-[1.5rem] overflow-hidden"
                                                        clas='bg-[ <%= product.panelcolor || ' rgba(255,255,255,0.02)'
                                                        %>]'>
                                                        <div
                                                            class="flex h-24 w-24 md:h-auto md:w-48 items-center justify-center relative overflow-hidden border-r border-white/10 shrink-0">
                                                            <% const imageSrc=Buffer.isBuffer(product.image)
                                                                ? 'data:image/jpeg;base64,' +
                                                                product.image.toString('base64') : (typeof
                                                                product.image==='string' ? product.image : '' ); %>
                                                                <% if (imageSrc) { %>
                                                                    <img class="h-full w-full object-cover opacity-90 relative z-10 transition-transform duration-[1800ms] group-hover:scale-105 group-hover:opacity-100"
                                                                        src="<%= imageSrc %>" alt="<%= product.name %>">
                                                                    <div
                                                                        class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent z-20 pointer-events-none">
                                                                    </div>
                                                                    <% } else { %>
                                                                        <div
                                                                            class="text-[10px] uppercase tracking-widest text-zinc-600 relative z-10">
                                                                            No Signal</div>
                                                                        <% } %>
                                                        </div>

                                                        <div
                                                            class="flex flex-1 items-center justify-between p-4 md:p-8">
                                                            <div>
                                                                <h3
                                                                    class="font-semibold text-sm md:text-xl tracking-tight mb-1 md:mb-2 text-[<%= product.textcolor || '#ffffff' %>]">
                                                                    <%= product.name %>
                                                                </h3>
                                                                <% if (Number(product.discount)> 0) { %>
                                                                    <div
                                                                        class="inline-flex glass-soft rounded-full px-2 md:px-3 py-1 md:py-1.5 text-[7px] md:text-[9px] uppercase tracking-[0.25em] font-bold text-white border border-white/20 shadow-[0_0_15px_rgba(255,255,255,0.1)] mt-0.5 md:mt-1">
                                                                        Saved: ₹ <%= Number(product.discount) %>
                                                                    </div>
                                                                    <% } %>
                                                            </div>
                                                            <div class="text-right flex flex-col justify-end">
                                                                <% if (Number(product.discount)> 0) { %>
                                                                    <p
                                                                        class="text-[9px] md:text-[11px] tracking-[0.1em] line-through text-zinc-500 mb-0.5 md:mb-1 opacity-50">
                                                                        ₹ <%= Number(product.price) || 0 %>
                                                                    </p>
                                                                    <% } %>
                                                                        <p
                                                                            class="text-base md:text-2xl font-bold tracking-[0.05em] text-[<%= product.textcolor || '#ffffff' %>]">
                                                                            ₹ <%= (Number(product.price) || 0) -
                                                                                (Number(product.discount) || 0) %>
                                                                        </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </article>
                                                <% }); %>
                                        </section>

                                        <aside class="lg:col-span-4 scroll-reveal delay-100">
                                            <div
                                                class="glass-soft rounded-[2rem] md:rounded-[2.5rem] p-6 md:p-8 lg:sticky lg:top-32 border border-white/10">
                                                <h2
                                                    class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-4 md:mb-6 border-b border-white/10 pb-3 md:pb-4">
                                                    Order Summary</h2>

                                                <div class="space-y-5 text-sm text-zinc-400 font-medium">
                                                    <div class="flex items-center justify-between">
                                                        <span>Subtotal</span>
                                                        <span class="text-zinc-200">₹ <%= subtotal %></span>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span>Discount</span>
                                                        <span class="text-emerald-400">- ₹ <%= discountTotal %></span>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span>Platform Protocol Fee</span>
                                                        <span class="text-zinc-200">₹ <%= platformFee %></span>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span>Shipping</span>
                                                        <span
                                                            class="text-white bg-white/10 border border-white/10 px-2 py-0.5 rounded text-xs uppercase tracking-widest">FREE</span>
                                                    </div>
                                                </div>

                                                <div class="my-6 h-px bg-white/10 w-full"></div>

                                                <div class="flex items-end justify-between font-bold">
                                                    <span
                                                        class="text-zinc-200 uppercase tracking-widest text-[9px] md:text-[11px]">Total</span>
                                                    <span class="text-2xl md:text-3xl text-white tracking-tight">₹ <%=
                                                            finalBill %></span>
                                                </div>

                                                <button
                                                    class="w-full mt-8 md:mt-10 btn-liquid inline-flex items-center justify-center rounded-full bg-white text-black px-6 md:px-8 py-4 md:py-5 text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] hover:-translate-y-0.5 transition shadow-[0_0_30px_rgba(255,255,255,0.15)]">
                                                    Initialize Checkout
                                                </button>

                                                <div
                                                    class="mt-6 text-center text-[10px] uppercase tracking-widest text-zinc-600">
                                                    Secure Encrypted Transaction</div>
                                            </div>
                                        </aside>
                                    </div>
                                    <% } %>
                        </main>

                        <script>
                            document.addEventListener("DOMContentLoaded", () => {
                                const observer = new IntersectionObserver((entries) => {
                                    entries.forEach(entry => {
                                        if (entry.isIntersecting) {
                                            entry.target.classList.add('in-view');
                                        }
                                    });
                                }, { threshold: 0.1 });
                                document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
                            });
                        </script>

                        <%- include('./partials/footer') %>
<%- include('./partials/header') %>

<% if(typeof success !=='undefined' && success.length>0){ %>
    <div class="fixed top-24 left-1/2 z-[70] -translate-x-1/2 px-6 py-3 rounded-full glass-soft border border-emerald-500/30 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
        <span class="inline-flex items-center gap-2 text-emerald-300 text-[10px] uppercase tracking-[0.2em] font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <%= success %>
        </span>
    </div>
<% } %>

<% if(typeof error !=='undefined' && error && error.length>0){ %>
    <div class="fixed top-24 left-1/2 z-[70] -translate-x-1/2 px-6 py-3 rounded-full glass-soft border border-red-500/30 shadow-[0_0_20px_rgba(239,68,68,0.15)]">
        <span class="inline-flex items-center gap-2 text-red-300 text-[10px] uppercase tracking-[0.2em] font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
            <%= error %>
        </span>
    </div>
<% } %>

<main class="w-full min-h-screen pt-28 md:pt-36 pb-20 px-5 md:px-12 lg:px-20 relative z-10 text-white">
    
    <div class="mb-10 md:mb-12 scroll-reveal text-center md:text-left">
        <span class="text-[10px] uppercase tracking-[0.35em] text-fuchsia-400 font-bold">Encrypted Access</span>
        <h1 class="mt-4 text-3xl md:text-5xl font-semibold tracking-[-0.05em] text-glow">Admin Command</h1>
    </div>

    <div class="flex flex-col lg:flex-row items-start gap-10">
        
        <!-- Sidebar -->
        <aside class="w-full lg:w-1/4 lg:sticky top-32 glass-soft rounded-[1.5rem] md:rounded-[2rem] p-6 md:p-8 border border-white/10 scroll-reveal delay-100">
            <div class="flex flex-col gap-4 w-full">
                <h4 class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-4">Command Modules</h4>
                
                <a class="flex items-center gap-3 text-white bg-white/10 border border-white/20 px-5 py-4 rounded-[1.25rem] text-[11px] uppercase tracking-[0.2em] font-bold shadow-[0_0_15px_rgba(255,255,255,0.05)] transition-all" href="/owners/products">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_10px_rgba(34,211,238,0.8)]"></span>
                    Terminal Database
                </a>
                
                <a class="flex items-center gap-3 text-zinc-400 hover:text-white hover:bg-white/5 border border-transparent px-5 py-4 rounded-[1.25rem] text-[11px] uppercase tracking-[0.2em] font-bold transition-all" href="/owners/admin">
                    <span class="w-1.5 h-1.5 rounded-full bg-zinc-600"></span>
                    Synthesize Piece
                </a>
            </div>
        </aside>

        <!-- Main Panel -->
        <div class="w-full lg:w-3/4 flex flex-col gap-6 md:gap-8 scroll-reveal delay-200">
            
            <div class="flex flex-col md:flex-row justify-between md:items-center gap-4 md:gap-6 glass-soft rounded-[1.5rem] md:rounded-[2rem] p-6 md:p-8 border border-white/10">
                <div>
                    <h2 class="text-xl md:text-2xl font-semibold tracking-tight text-white mb-1">Active Inventory</h2>
                    <p class="text-[11px] uppercase tracking-[0.1em] text-zinc-500"><%= products.length %> Pieces Registered</p>
                </div>
                <!-- Optional: destructive action -->
            </div>

            <!-- Products Grid -->
            <div class="grid grid-cols-2 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
                <% (products || []).forEach(function(product, index) { %>
                    <div class="scroll-reveal delay-<%= Math.min((index%3)*100, 300) %>">
                        <div class="group relative overflow-hidden rounded-[1.5rem] md:rounded-[2.5rem] glass-liquid glass-stroke p-1.5 md:p-2 transition-all duration-700 flex flex-col h-full hover:shadow-[0_30px_60px_rgba(0,0,0,0.4)]"
                             style="background-color: <%= product.bgcolor || '#040405' %>60;">
                            
                            <!-- Image -->
                            <div class="w-full aspect-[4/5] md:aspect-[3/4] relative overflow-hidden rounded-[1.25rem] md:rounded-[2rem] transition-transform duration-700 group-hover:scale-[0.98]"
                                 style="background-color: <%= product.panelcolor || 'rgba(255,255,255,0.03)' %>;">
                                <% if(product.image) { %>
                                    <img class="absolute inset-0 h-full w-full object-cover opacity-90 group-hover:opacity-100 transition-all duration-[2000ms] group-hover:scale-110 filter brightness-[1.02]" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>">
                                <% } else { %>
                                    <div class="absolute inset-0 flex items-center justify-center text-[10px] uppercase tracking-widest font-bold text-zinc-600">No Signal</div>
                                <% } %>
                                
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60"></div>
                                
                                <div class="absolute top-3 md:top-5 right-3 md:right-5 md:translate-y-4 md:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 z-20">
                                    <a class="flex items-center justify-center w-8 h-8 md:w-12 md:h-12 rounded-full glass-soft text-white hover:bg-white hover:text-black transition-all shadow-[0_0_20px_rgba(255,255,255,0.1)] border border-white/20" href="/owners/edit-product/<%= product._id %>" title="Modify Interface">
                                        <i class="ri-settings-4-fill text-sm md:text-xl"></i>
                                    </a>
                                </div>
                            </div>
                            
                            <!-- Info -->
                            <div class="p-5 md:p-8 flex-1 flex flex-col justify-end relative z-10">
                                <div class="flex items-start justify-between gap-4 mb-2">
                                    <div>
                                        <div class="inline-flex items-center gap-1.5 mb-2">
                                            <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse"></span>
                                            <span class="text-[8px] uppercase tracking-[0.3em] font-black text-emerald-400">Live</span>
                                        </div>
                                        <h3 class="font-bold text-xs md:text-lg tracking-tight transition-colors duration-500" 
                                            style="color: <%= product.textcolor || '#ffffff' %>;"><%= product.name %></h3>
                                    </div>
                                    <div class="text-right">
                                        <h4 class="font-bold text-[10px] md:text-base tracking-tighter" style="color: <%= product.textcolor || '#ffffff' %>;">₹<%= product.price %></h4>
                                        <span class="text-[8px] uppercase tracking-[0.2em] text-zinc-500 font-bold">Yield</span>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                <% }) %>
                
                <% if (!products || products.length === 0) { %>
                    <div class="col-span-full glass-soft rounded-[2rem] p-16 text-center border border-white/5">
                        <h3 class="text-xl font-semibold tracking-tight text-white mb-2">No Data Signals</h3>
                        <p class="text-zinc-500 text-sm">The database is currently empty. Synthesize a new piece to populate.</p>
                        <a href="/owners/admin" class="mt-8 btn-liquid inline-flex items-center justify-center rounded-full bg-white text-black px-6 py-3 text-[10px] font-bold uppercase tracking-[0.2em] transition">Synthesize</a>
                    </div>
                <% } %>
            </div>
            
        </div>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
    });
</script>

<%- include('./partials/footer') %>
<%- include('./partials/header') %>

    <% if(typeof success !=='undefined' && success.length>0){ %>
        <div
            class="fixed top-24 left-1/2 -translate-x-1/2 z-[70] px-6 py-3 rounded-full glass-soft border border-emerald-500/30 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
            <span
                class="inline-flex items-center gap-2 text-emerald-300 text-[10px] uppercase tracking-[0.2em] font-bold">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                <%= success %>
            </span>
        </div>
        <% } %>

            <% if(typeof error !=='undefined' && error && error.length>0){ %>
                <div
                    class="fixed top-24 left-1/2 -translate-x-1/2 z-[70] px-6 py-3 rounded-full glass-soft border border-red-500/30 shadow-[0_0_20px_rgba(239,68,68,0.15)]">
                    <span
                        class="inline-flex items-center gap-2 text-red-300 text-[10px] uppercase tracking-[0.2em] font-bold">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                        <%= error %>
                    </span>
                </div>
                <% } %>

                    <main
                        class="w-full min-h-screen pt-28 md:pt-36 pb-20 px-5 md:px-12 lg:px-20 relative z-10 text-white">

                        <div
                            class="mb-12 md:mb-16 scroll-reveal flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/5 pb-8 md:pb-12">
                            <div class="text-center md:text-left">
                                <span
                                    class="text-[10px] uppercase tracking-[0.4em] text-zinc-500 font-bold mb-3 block">Scanning
                                    Records...</span>
                                <h1
                                    class="text-4xl md:text-6xl font-semibold tracking-[-0.05em] text-glow leading-none">
                                    Complete <span
                                        class="text-transparent bg-clip-text bg-gradient-to-r from-white to-white/40">Archive</span>
                                </h1>
                            </div>
                            <div class="flex flex-col items-center md:items-end">
                                <span class="text-[9px] uppercase tracking-[0.3em] text-zinc-600 font-bold mb-1">Status:
                                    Operational</span>
                                <p class="text-xs font-medium tracking-[0.1em] text-zinc-400">Showing <%=
                                        products.length %> Registered Pieces</p>
                            </div>
                        </div>

                        <div class="flex flex-col lg:flex-row items-start gap-10">

                            <!-- Sidebar -->
                            <aside
                                class="w-full lg:w-1/4 lg:sticky top-32 glass-soft rounded-[2rem] p-8 border border-white/5 scroll-reveal delay-100">
                                <div class="flex flex-col gap-10 w-full">

                                    <!-- Sort -->
                                    <div class="w-full">
                                        <h3
                                            class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-6 flex items-center gap-3">
                                            <span class="w-1.5 h-1.5 rounded-full bg-zinc-700"></span> Sort Protocol
                                        </h3>
                                        <form action="/shop" class="w-full relative group">
                                            <select
                                                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-zinc-300 focus:outline-none focus:border-white/30 cursor-pointer text-[10px] appearance-none uppercase tracking-[0.2em] font-bold transition-all hover:bg-white/[0.08]"
                                                name="sortby" onchange="this.form.submit()">
                                                <option value="popular" class="bg-zinc-900">Popularity Rank</option>
                                                <option value="newest" class="bg-zinc-900">Latest Edition</option>
                                            </select>
                                            <i
                                                class="ri-arrow-down-s-line absolute right-5 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none group-hover:text-white transition-colors"></i>
                                        </form>
                                    </div>

                                    <!-- Collections -->
                                    <div class="w-full">
                                        <h3
                                            class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-6 flex items-center gap-3">
                                            <span class="w-1.5 h-1.5 rounded-full bg-zinc-700"></span> Filter Archive
                                        </h3>
                                        <div class="flex flex-col gap-4">
                                            <a class="text-zinc-500 text-[11px] uppercase tracking-[0.2em] font-bold hover:text-white transition-all flex items-center justify-between group"
                                                href="/shop">
                                                <span>All Products</span>
                                                <i
                                                    class="ri-arrow-right-s-line opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0"></i>
                                            </a>
                                            <a class="text-zinc-500 text-[11px] uppercase tracking-[0.2em] font-bold hover:text-cyan-400 transition-all flex items-center justify-between group"
                                                href="/new-collection">
                                                <span>New Arrivals</span>
                                                <i
                                                    class="ri-arrow-right-s-line opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0"></i>
                                            </a>
                                            <a class="text-zinc-500 text-[11px] uppercase tracking-[0.2em] font-bold hover:text-emerald-400 transition-all flex items-center justify-between group"
                                                href="/discounted-products">
                                                <span>Reserve & Sale</span>
                                                <i
                                                    class="ri-arrow-right-s-line opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0"></i>
                                            </a>
                                        </div>
                                    </div>

                                    <!-- System Info (Decorative) -->
                                    <div class="pt-6 border-t border-white/5">
                                        <div class="flex items-center gap-3 text-zinc-700 mb-2">
                                            <span class="text-[8px] font-bold uppercase tracking-widest">Interface
                                                v4.2</span>
                                        </div>
                                        <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
                                            <div class="h-full w-2/3 bg-white/20 animate-pulse"></div>
                                        </div>
                                    </div>

                                </div>
                            </aside>

                            <!-- Products Grid -->
                            <div
                                class="w-full lg:w-3/4 grid grid-cols-2 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
                                <% (products || []).forEach(function(product, index){ %>
                                    <div class="scroll-reveal delay-<%= Math.min((index%3)*100, 300) %>">
                                        <div
                                            class="bg-[<%= product.bgcolor || '#040405' %>80] product-card group relative overflow-hidden rounded-[1.5rem] md:rounded-[2.5rem] glass-liquid glass-stroke p-1.5 md:p-2 transition-all duration-700 flex flex-col h-full hover:shadow-[0_40px_80px_rgba(0,0,0,0.6)]">

                                            <!-- Image Stage -->
                                            <div
                                                class="bg-[<%= product.pannelcolor || 'rgba(255,255,255,0.03)' %>] relative aspect-[4/5] md:aspect-[3/4] overflow-hidden rounded-[1.25rem] md:rounded-[2rem] transition-transform duration-700 group-hover:scale-[0.98]">

                                                <% if(product.image) { %>
                                                    <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                                        alt="<%= product.name %>"
                                                        class="absolute inset-0 h-full w-full object-cover mix-blend-normal opacity-95 group-hover:opacity-100 group-hover:scale-110 transition duration-[2000ms] ease-out filter brightness-[1.02] contrast-[1.05]" />
                                                    <% } else { %>
                                                        <div
                                                            class="absolute inset-0 flex items-center justify-center text-zinc-700 text-[10px] uppercase tracking-widest font-bold">
                                                            Signal Lost</div>
                                                        <% } %>

                                                            <!-- Overlay Gradients for Depth -->
                                                            <div
                                                                class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60">
                                                            </div>
                                                            <div
                                                                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 bg-gradient-to-tr from-white/5 via-transparent to-white/5">
                                                            </div>

                                                            <% const originalPrice=Number(product.price) || 0; %>
                                                                <% const discountAmount=Number(product.discount) || 0;
                                                                    %>
                                                                    <% const validDiscount=discountAmount> 0 &&
                                                                        discountAmount < originalPrice; %>

                                                                            <% if(validDiscount) { %>
                                                                                <div
                                                                                    class="absolute top-3 md:top-5 left-3 md:left-5 glass-soft rounded-full px-2 md:px-3 py-1 md:py-1.5 text-[8px] md:text-[10px] uppercase tracking-[0.25em] font-black text-white border border-white/20 shadow-[0_0_20px_rgba(255,255,255,0.1)]">
                                                                                    -<%= Math.round((discountAmount /
                                                                                        originalPrice) * 100) %>%
                                                                                </div>
                                                                                <% } %>

                                                                                    <!-- Quick Action Area -->
                                                                                    <div
                                                                                        class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 scale-90 group-hover:scale-100 pointer-events-none">
                                                                                        <span
                                                                                            class="bg-white/90 text-black px-6 py-3 rounded-full text-[9px] uppercase tracking-[0.3em] font-black shadow-2xl">View
                                                                                            Details</span>
                                                                                    </div>
                                            </div>

                                            <!-- Info with Dynamic Text Color -->
                                            <div class="p-5 md:p-8 flex-1 flex flex-col justify-end relative z-10">
                                                <div class="flex items-start justify-between gap-4 mb-3">
                                                    <div>
                                                        <h3
                                                            class="text-[<%= product.textcolor || '#ffffff' %>] text-sm md:text-xl font-bold tracking-[-0.02em] leading-tight transition-colors duration-500">
                                                            <%= product.name %>
                                                        </h3>
                                                    </div>
                                                    <div class="text-right">
                                                        <% const finalPrice=validDiscount ? (originalPrice -
                                                            discountAmount) : originalPrice; %>
                                                            <div
                                                                class="text-[<%= product.textcolor || '#ffffff' %>] font-bold text-sm md:text-xl tracking-tighter">
                                                                ₹<%= finalPrice %>
                                                            </div>
                                                            <% if(validDiscount) { %>
                                                                <div
                                                                    class="text-[9px] md:text-[11px] tracking-tight text-zinc-500 line-through opacity-50">
                                                                    ₹<%= originalPrice %>
                                                                </div>
                                                                <% } %>
                                                    </div>
                                                </div>

                                                <a href="/add-to-cart/<%= product._id %>"
                                                    class="w-full mt-4 py-4 rounded-xl border border-white/10 bg-white/5 flex items-center justify-center gap-3 text-[10px] uppercase tracking-[0.25em] font-black text-white hover:bg-white hover:text-black transition-all duration-500 group-hover:border-white">
                                                    <i class="ri-add-line text-lg"></i>
                                                    Acquisition
                                                </a>
                                            </div>

                                        </div>
                                    </div>
                                    <% }) %>

                                        <% if(!products || products.length===0) { %>
                                            <div class="col-span-full glass-soft rounded-[2rem] p-16 text-center">
                                                <h3 class="text-2xl font-semibold tracking-tight mb-3">Archive Empty
                                                </h3>
                                                <p class="text-zinc-500 max-w-sm mx-auto text-sm">No pieces found
                                                    matching your current protocol. Adjust filters or return to all
                                                    products.</p>
                                                <a href="/shop"
                                                    class="mt-8 btn-liquid inline-flex items-center justify-center rounded-full bg-white text-black px-8 py-3.5 text-[10px] font-bold uppercase tracking-[0.2em] hover:-translate-y-0.5 transition">Clear
                                                    Filters</a>
                                            </div>
                                            <% } %>

                            </div>
                        </div>
                    </main>

                    <script>
                        document.addEventListener("DOMContentLoaded", () => {
                            const observer = new IntersectionObserver((entries) => {
                                entries.forEach(entry => {
                                    if (entry.isIntersecting) {
                                        entry.target.classList.add('in-view');
                                    }
                                });
                            }, { threshold: 0.1 });
                            document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
                        });
                    </script>

                    <%- include('./partials/footer') %>
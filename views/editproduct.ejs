<%- include('./partials/header') %>

<% if(typeof success !== 'undefined' && success.length>0){ %>
    <div class="fixed top-24 left-1/2 z-[70] -translate-x-1/2 px-6 py-3 rounded-full glass-soft border border-emerald-500/30 shadow-[0_0_20px_rgba(16,185,129,0.15)]">
        <span class="inline-flex items-center gap-2 text-emerald-300 text-[10px] uppercase tracking-[0.2em] font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <%= success %>
        </span>
    </div>
<% } %>

<% if(typeof error !== 'undefined' && error && error.length>0){ %>
    <div class="fixed top-24 left-1/2 z-[70] -translate-x-1/2 px-6 py-3 rounded-full glass-soft border border-red-500/30 shadow-[0_0_20px_rgba(239,68,68,0.15)]">
        <span class="inline-flex items-center gap-2 text-red-300 text-[10px] uppercase tracking-[0.2em] font-bold">
            <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
            <%= error %>
        </span>
    </div>
<% } %>

<main class="w-full min-h-screen pt-28 md:pt-36 pb-20 px-5 md:px-12 lg:px-20 relative z-10 text-white">
    
    <div class="mb-10 md:mb-12 scroll-reveal text-center md:text-left">
        <span class="text-[10px] uppercase tracking-[0.35em] text-fuchsia-400 font-bold">Encrypted Access</span>
        <h1 class="mt-4 text-3xl md:text-5xl font-semibold tracking-[-0.05em] text-glow">Admin Command</h1>
    </div>

    <div class="flex flex-col lg:flex-row items-start gap-10">
        <!-- Sidebar -->
        <aside class="w-full lg:w-1/4 lg:sticky top-32 glass-soft rounded-[1.5rem] md:rounded-[2rem] p-6 md:p-8 border border-white/10 scroll-reveal delay-100">
            <div class="flex flex-col gap-4 w-full">
                <h4 class="text-[10px] uppercase tracking-[0.35em] text-zinc-500 font-bold mb-4">Command Modules</h4>
                
                <a class="flex items-center gap-3 text-zinc-400 hover:text-white hover:bg-white/5 border border-transparent px-5 py-4 rounded-[1.25rem] text-[11px] uppercase tracking-[0.2em] font-bold transition-all" href="/owners/products">
                    <span class="w-1.5 h-1.5 rounded-full bg-zinc-600"></span>
                    Terminal Database
                </a>

                <a class="flex items-center gap-3 text-white bg-white/10 border border-white/20 px-5 py-4 rounded-[1.25rem] text-[11px] uppercase tracking-[0.2em] font-bold shadow-[0_0_15px_rgba(255,255,255,0.05)] transition-all" href="/owners/admin">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_10px_rgba(34,211,238,0.8)]"></span>
                    Synthesize Piece
                </a>
            </div>
        </aside>
        
        <!-- Main Form Panel -->
        <div class="w-full lg:w-3/4 scroll-reveal delay-200">
            <div class="glass-liquid glass-stroke rounded-[1.5rem] md:rounded-[2rem] p-6 md:p-12 border border-white/10 relative overflow-hidden bg-[#040405]">
                
                <h2 class="text-xl md:text-2xl font-semibold tracking-tight text-white mb-6 md:mb-8 border-b border-white/10 pb-4 md:pb-6">Modify Formulation</h2>
                
                <form action="/products/update/<%= product._id %>" method="post" enctype="multipart/form-data" class="relative z-10">
                    <div class="mb-10">
                        <h3 class="text-[10px] uppercase tracking-[0.3em] font-bold text-zinc-400 mb-6 flex items-center gap-2">
                            <span class="w-1 h-1 rounded-full bg-white/40"></span> Metadata Adjustments
                        </h3>
                        
                        <div class="mb-4 md:mb-6">
                            <label class="block mb-2 md:mb-3 text-[10px] md:text-[11px] uppercase tracking-[0.1em] font-medium text-zinc-400">Visual Feed (Image) <span class="text-zinc-600 lowercase font-normal">(Leave blank to keep current)</span></label>
                            <input name="image" type="file" class="w-full py-3 md:py-4 px-4 md:px-5 rounded-[1rem] bg-white/5 border border-white/10 text-zinc-400 file:mr-4 md:file:mr-5 file:py-2 md:file:py-2.5 file:px-4 md:file:px-5 file:rounded-full file:border-0 file:text-[9px] md:file:text-[10px] file:font-bold file:uppercase file:tracking-[0.2em] file:bg-white file:text-black hover:file:bg-zinc-200 hover:file:cursor-pointer transition-colors focus:outline-none focus:border-cyan-400/50 cursor-pointer">
                            <% if(product.image) { %>
                                <div class="mt-4 md:mt-6 flex items-center gap-4 md:gap-6 glass-soft border border-white/5 rounded-[1.25rem] md:rounded-[1.5rem] p-3 md:p-4 w-fit">
                                    <div class="relative w-16 h-16 md:w-20 md:h-20 rounded-lg md:rounded-xl overflow-hidden bg-black/40">
                                        <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" class="h-full w-full object-cover opacity-80">
                                    </div>
                                    <p class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-500">Current<br/>Visual Data</p>
                                </div>
                            <% } %>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                            <div class="space-y-2 md:space-y-3">
                                <label class="block text-[10px] md:text-[11px] uppercase tracking-[0.1em] font-medium text-zinc-400">Designation (Name)</label>
                                <input name="name" type="text" value="<%= product.name %>" class="w-full py-3.5 md:py-4 px-4 md:px-5 rounded-[1rem] bg-white/5 border border-white/10 text-white placeholder-zinc-600 focus:outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-colors">
                            </div>
                            
                            <div class="space-y-2 md:space-y-3">
                                <label class="block text-[10px] md:text-[11px] uppercase tracking-[0.1em] font-medium text-zinc-400">Yield Value (Price)</label>
                                <input name="price" type="text" value="<%= product.price %>" class="w-full py-3.5 md:py-4 px-4 md:px-5 rounded-[1rem] bg-white/5 border border-white/10 text-white placeholder-zinc-600 focus:outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-colors">
                            </div>
 
                            <div class="space-y-2 md:space-y-3 md:col-span-2 lg:col-span-1">
                                <label class="block text-[10px] md:text-[11px] uppercase tracking-[0.1em] font-medium text-zinc-400">Offset Amount (Discount)</label>
                                <input name="discount" type="text" value="<%= product.discount %>" class="w-full py-3.5 md:py-4 px-4 md:px-5 rounded-[1rem] bg-white/5 border border-white/10 text-white placeholder-zinc-600 focus:outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-colors">
                            </div>
                        </div>
                    </div>

                    <div class="mb-10">
                        <h3 class="text-[10px] uppercase tracking-[0.3em] font-bold text-zinc-400 mb-6 flex items-center gap-2">
                            <span class="w-1 h-1 rounded-full bg-white/40"></span> Interface Colors
                        </h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <!-- Color Base -->
                            <div class="flex items-center bg-white/5 border border-white/10 rounded-[1rem] p-3 gap-4 transition-colors focus-within:border-cyan-400/50 focus-within:bg-white/10">
                                <div class="relative w-12 h-12 rounded-full overflow-hidden border border-white/20 shrink-0 shadow-[0_0_10px_rgba(255,255,255,0.05)]">
                                    <input type="color" oninput="document.getElementById('bgcolor_input').value=this.value" class="absolute -top-4 -left-4 w-24 h-24 cursor-pointer" value="<%= product.bgcolor || '#ffffff' %>">
                                </div>
                                <div class="flex flex-col flex-1">
                                    <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-[0.2em] mb-1">Canvas Base</label>
                                    <input id="bgcolor_input" name="bgcolor" type="text" value="<%= product.bgcolor %>" class="w-full bg-transparent outline-none text-white text-xs font-medium uppercase tracking-widest">
                                </div>
                            </div>
                            
                            <!-- Panel Color -->
                            <div class="flex items-center bg-white/5 border border-white/10 rounded-[1rem] p-3 gap-4 transition-colors focus-within:border-cyan-400/50 focus-within:bg-white/10">
                                <div class="relative w-12 h-12 rounded-full overflow-hidden border border-white/20 shrink-0 shadow-[0_0_10px_rgba(255,255,255,0.05)]">
                                    <input type="color" oninput="document.getElementById('panelcolor_input').value=this.value" class="absolute -top-4 -left-4 w-24 h-24 cursor-pointer" value="<%= product.panelcolor || product.pannelcolor || '#ffffff' %>">
                                </div>
                                <div class="flex flex-col flex-1">
                                    <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-[0.2em] mb-1">Panel Layer</label>
                                    <input id="panelcolor_input" name="panelcolor" type="text" value="<%= product.panelcolor || product.pannelcolor %>" class="w-full bg-transparent outline-none text-white text-xs font-medium uppercase tracking-widest">
                                </div>
                            </div>

                            <!-- Text Color -->
                            <div class="flex items-center bg-white/5 border border-white/10 rounded-[1rem] p-3 gap-4 transition-colors focus-within:border-cyan-400/50 focus-within:bg-white/10">
                                <div class="relative w-12 h-12 rounded-full overflow-hidden border border-white/20 shrink-0 shadow-[0_0_10px_rgba(255,255,255,0.05)]">
                                    <input type="color" oninput="document.getElementById('textcolor_input').value=this.value" class="absolute -top-4 -left-4 w-24 h-24 cursor-pointer" value="<%= product.textcolor || '#000000' %>">
                                </div>
                                <div class="flex flex-col flex-1">
                                    <label class="text-[9px] uppercase font-bold text-zinc-500 tracking-[0.2em] mb-1">Typography</label>
                                    <input id="textcolor_input" name="textcolor" type="text" value="<%= product.textcolor %>" class="w-full bg-transparent outline-none text-white text-xs font-medium uppercase tracking-widest">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="pt-6 md:pt-8 border-t border-white/10 flex flex-col md:flex-row gap-4 items-center">
                        <button class="w-full md:w-auto btn-liquid px-10 md:px-12 py-4 md:py-5 rounded-full font-bold text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-black bg-white hover:-translate-y-0.5 transition-transform" type="submit">
                            Confirm Adjustments
                        </button>
                    </div>
                </form>

                <!-- Destructive Action -->
                <form action="/products/delete/<%= product._id %>" method="post" class="md:absolute md:bottom-12 md:right-12 mt-6 md:mt-0 w-full md:w-auto">
                    <button type="submit" class="w-full md:w-auto px-6 md:px-8 py-4 md:py-5 rounded-full font-bold text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-red-500 glass-soft border border-red-500/10 hover:bg-red-500 hover:text-white transition-all shadow-[0_0_30px_rgba(239,68,68,0.05)]" onclick="return confirm('Confirm destructive deletion protocol?');">
                        Terminate Piece
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
    });
</script>

<%- include('./partials/footer') %>
